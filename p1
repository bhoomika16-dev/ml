import numpy as np
import matplotlib.pyplot as plt
from sklearn.neighbors import KNeighborsClassifier from sklearn.metrics import accuracy_score

# Step 1: Generate 100 random points in the range [0,1] np.random.seed(42) # For reproducibility
X = np.random.rand(100, 1)

# Step 2: Label the first 50 points y = np.zeros(100)
y[:50] = 1 # Label Class 1 for the first 50 points (xi <= 0.5) y[50:] = 2 # Label Class 2 for the remaining points (xi > 0.5)

# Step 3: Split the data into training and testing sets X_train = X[:50] # First 50 points as training data
y_train = y[:50] # Corresponding labels for the first 50 points X_test = X[50:] # Remaining points as testing data
y_test = y[50:] # Corresponding labels for the remaining points

# Step 4: Classify the test set using KNN for different values of k k_values = [1, 2, 3, 4, 5, 20, 30]
accuracy_results = []

for k in k_values:
knn = KNeighborsClassifier(n_neighbors=k) knn.fit(X_train, y_train)

# Make predictions for the test set y_pred = knn.predict(X_test)

# Calculate the accuracy of the model accuracy = accuracy_score(y_test, y_pred) accuracy_results.append(accuracy)

print(f"Accuracy for k={k}: {accuracy:.4f}")

# Step 5: Visualize the results plt.figure(figsize=(10, 6))

for k, accuracy in zip(k_values, accuracy_results):
plt.plot(k, accuracy, 'o', label=f'k={k} (Acc={accuracy:.2f})')

plt.title('KNN Classifier Accuracy for Different k Values') plt.xlabel('k')
plt.ylabel('Accuracy') plt.legend() plt.grid(True)
plt.show()

