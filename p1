# Find-S Algorithm Implementation def find_s(X, y):
# Initialize hypothesis to the first positive example hypothesis = None

for i in range(len(y)):
if y[i] == "Yes": # Consider only positive examples if hypothesis is None:
hypothesis = X.iloc[i].values # First positive example else:
# Generalize hypothesis
for j in range(len(hypothesis)):
if hypothesis[j] != X.iloc[i, j]: hypothesis[j] = "?" # Generalize
return hypothesis # Run Find-S Algorithm
hypothesis = find_s(X, y)

# Print the output hypothesis print("Final Hypothesis:", hypothesis)

